{
  "buildCommand": "npm run build && mkdir -p apps/play/dist/lab && cp -R apps/lab/dist/* apps/play/dist/lab/",
  "outputDirectory": "apps/play/dist",
  "installCommand": "npm install",
  "rewrites": [
    {
      "source": "/lab",
      "destination": "/lab/index.html"
    },
    {
      "source": "/lab/:path*",
      "destination": "/lab/index.html"
    },
    {
      "source": "/solver",
      "destination": "/lab/index.html"
    },
    {
      "source": "/solver/:path*",
      "destination": "/lab/index.html"
    },
    {
      "source": "/keyboard",
      "destination": "/index.html"
    },
    {
      "source": "/keyboard/:path*",
      "destination": "/index.html"
    }
  ]
}
